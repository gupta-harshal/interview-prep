{
  "manifest_version": 3,
  "name": "DevSRS Capture Engine",
  "version": "1.0.0",
  "description": "Capture LeetCode patterns and system design concepts instantly into your SRS queue.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.leetcode.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": "vite.svg"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}